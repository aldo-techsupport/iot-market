  "example_3_iot_device_sends_data": {
    "endpoint": "POST /api/iot/data",
    "description": "Device mengirim 5 sensor, tapi hanya 3 yang diaktifkan",
    "request": {
      "device_id": "TEMP001",
      "temperature": 25.5,
      "humidity": 60.0,
      "air_quality": 45,
      "noise": 55.0,
      "light_intensity": 850.0
    },
    "response": {
      "success": true,
      "message": "Data berhasil disimpan",
      "data": {
        "id": 1,
        "device_id": "TEMP001",
        "temperature": 25.5,
        "humidity": 60.0,
        "air_quality": 45,
        "created_at": "2026-02-25T10:35:00.000000Z",
        "updated_at": "2026-02-25T10:35:00.000000Z"
      }
    },
    "note": "noise dan light_intensity TIDAK disimpan karena tidak diaktifkan di device settings"
  },
  "example_4_sensor_not_allowed": {
    "endpoint": "POST /api/iot/data",
    "description": "Device mengirim sensor yang tidak diaktifkan",
    "request": {
      "device_id": "TEMP001",
      "noise": 55.0,
      "light_intensity": 850.0
    },
    "response": {
      "success": false,
      "message": "Tidak ada sensor yang diizinkan untuk device ini",
      "enabled_sensors": [
        "temperature",
        "humidity",
        "air_quality"
      ]
    }
  },
