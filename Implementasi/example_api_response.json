  "example_2_create_device_with_selected_sensors": {
    "endpoint": "POST /api/devices",
    "request": {
      "device_id": "TEMP001",
      "device_name": "Sensor Suhu Ruangan",
      "description": "Monitoring ruang server",
      "sensors": [
        "temperature",
        "humidity",
        "air_quality"
      ]
    },
    "response": {
      "success": true,
      "message": "Device berhasil dibuat",
      "data": {
        "device": {
          "id": 1,
